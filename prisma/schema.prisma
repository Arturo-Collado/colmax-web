generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id_usuario     Int      @id @default(autoincrement())
  nombre_usuario String   @unique
  contrasena     String
  correo         String
  rol            String
  fecha_creacion DateTime @default(now())
}

model Artista {
  id_artista       Int        @id @default(autoincrement())
  nombre_artistico String
  nombre_real      String
  genero_musical   String
  estado           String     @default("Activo")
  fecha_registro   DateTime   @default(now())
  contratos        Contrato[]
}

model Contrato {
  id_contrato           Int      @id @default(autoincrement())
  id_artista            Int
  fecha_de_inicio       DateTime
  fecha_de_finalizacion DateTime
  estado                String   @default("Vigente")
  artista               Artista  @relation(fields: [id_artista], references: [id_artista])
}

model Venta {
  id_venta     Int      @id @default(autoincrement())
  tipo         String
  ganancia     Decimal  @db.Decimal(18, 2)
  fecha_evento DateTime @default(now())
}